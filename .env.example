# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Trading mode ─────────────────────────────────────────────────────────────
# "demo" (default) — paper trading only
# "real"           — live orders (also requires REAL_TRADING=true)
MODE=demo

# Second safety gate: must be explicitly "true" to allow live orders
REAL_TRADING=false

# ─── Exchange sync ────────────────────────────────────────────────────────────
# Sync portfolio from Binance on startup + every cycle (real mode only)
SYNC_EXCHANGE_ON_STARTUP=true
# Minimum holding value (USDT) to import as a position (filters dust)
SYNC_MIN_VALUE_USDT=1.0

# ─── Bot behaviour ────────────────────────────────────────────────────────────
# How often the bot runs a full analysis cycle (seconds)
CYCLE_INTERVAL_SECONDS=300

# Starting paper-money balance for demo mode (USDT)
DEMO_INITIAL_BALANCE=1000.0

# Max % of total portfolio in a single trade (hard cap)
MAX_POSITION_PCT=40.0

# Max total altcoin exposure as % of portfolio
MAX_TOTAL_EXPOSURE_PCT=85.0

# Auto-adjust risk profile based on market regime (true/false)
AUTO_RISK_PROFILE=true

# Max drawdown circuit breaker — pauses bot if portfolio drops this % from peak
MAX_DRAWDOWN_PCT=15.0

# Discord webhook URL for trade notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=

# ─── Auto-backtest & tuning ───────────────────────────────────────────────────
# Run backtest on bot startup to auto-tune scorer settings (true/false)
AUTO_BACKTEST=true
# Re-run backtest every N hours (0 = startup only)
BACKTEST_INTERVAL_HOURS=6
# Days of history per backtest (30 = good balance of speed vs accuracy)
BACKTEST_DAYS=30
# Symbols to include in backtest
BACKTEST_SYMBOLS=16

# ─── DCA (Dollar-Cost Averaging) ─────────────────────────────────────────────
# Split BUY into 2 tranches for better average entry (true/false)
DCA_ENABLED=true
# First tranche as % of total position (rest is pending limit order)
DCA_SPLIT_PCT=60
# Dip % below entry for second tranche to fill
DCA_DIP_PCT=2.0

# ─── Kelly criterion sizing ──────────────────────────────────────────────────
# Scale position sizes using Kelly formula from backtest results
KELLY_SIZING=true
# Cap on Kelly fraction (0.5 = half-Kelly for safety)
KELLY_FRACTION_CAP=0.5

# ─── Time-based exit ─────────────────────────────────────────────────────────
# Max hours to hold a stagnant position (0 = disabled)
MAX_HOLD_HOURS=48

# ─── Pyramiding (add to winners) ─────────────────────────────────────────────
# Add to profitable positions when quant score remains high
PYRAMID_ENABLED=true
# Minimum P&L % before pyramiding is considered
PYRAMID_MIN_PNL_PCT=3.0
# Minimum quant score for pyramiding
PYRAMID_MIN_SCORE=70
# How much to add as % of original position value
PYRAMID_ADD_PCT=50

# ─── Quant scorer (signal-first architecture) ────────────────────────────────
# Minimum score (0-100) for a symbol to become a trade candidate
MIN_QUANT_SCORE=50
# ATR multiplier for stop-loss (1.5 = normal volatility buffer)
SL_ATR_MULTIPLIER=1.5
# Minimum reward-to-risk ratio (TP must be this multiple of SL)
MIN_REWARD_RISK_RATIO=2.0
# Stop-loss % floor and ceiling
MIN_SL_PCT=1.5
MAX_SL_PCT=10.0

# ─── Cost optimisation ────────────────────────────────────────────────────────
# Max symbols sent to Claude per cycle (0 = all, recommended 5-8)
MAX_PROMPT_SYMBOLS=15
# Skip Claude when market is flat and no strong signals (true/false)
SKIP_FLAT_CYCLES=true
# Use cheaper Haiku model for quiet cycles, Sonnet for actionable (true/false)
USE_HAIKU_FOR_HOLD=true

# Top gainers detection: min 24h % change to inject into universe
GAINER_MIN_PCT=8.0
# Max gainers to inject per cycle (on top of volume-based universe)
GAINER_INJECT_COUNT=5
# How many hours to auto-track newly listed coins (they get injected regardless of volume)
NEW_LISTING_WATCH_HOURS=1

# ─── News ─────────────────────────────────────────────────────────────────────
# CryptoCompare free API key (optional — leave blank for unauthenticated calls)
CRYPTOCOMPARE_API_KEY=

# ─── Remote GPU server (optional) ────────────────────────────────────────────
# Point to a machine running gpu-server/server.py for Transformer model,
# Dueling Double DQN, semantic sentiment, and full ensemble endpoint.
# No GPU required — the server falls back to CPU if CUDA is unavailable.
# Run locally: cd gpu-server && pip install -r requirements.txt && python server.py
GPU_SERVER_URL=http://localhost:9090
GPU_SERVER_TIMEOUT=120
# Shared auth token — must match GPU_SERVER_TOKEN on the GPU machine (leave blank to disable)
GPU_SERVER_TOKEN=

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production / Docker deployment)
DATABASE_URL=postgresql+asyncpg://ai_trader:ai_trader@localhost:5432/ai_trader
# SQLite alternative (for quick local dev without PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:////data/trader.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
