# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Quote currency ───────────────────────────────────────────────────────────
# USDT = larger universe, more liquidity. USDC = fewer but more stable pairs.
QUOTE_CURRENCY=USDC

# ─── Trading mode ─────────────────────────────────────────────────────────────
# "demo" (default) — paper trading only
# "real"           — live orders (also requires REAL_TRADING=true)
MODE=demo

# Second safety gate: must be explicitly "true" to allow live orders
REAL_TRADING=false

# ─── Exchange sync ────────────────────────────────────────────────────────────
# Sync portfolio from Binance on startup + every cycle (real mode only)
SYNC_EXCHANGE_ON_STARTUP=true
# Minimum holding value (USDT) to import as a position (filters dust)
SYNC_MIN_VALUE_USDT=1.0

# ─── Bot behaviour ────────────────────────────────────────────────────────────
# How often the bot runs a full analysis cycle (seconds)
CYCLE_INTERVAL_SECONDS=300

# Starting paper-money balance for demo mode (USDT)
DEMO_INITIAL_BALANCE=1000.0

# Max % of total portfolio in a single trade (hard cap)
MAX_POSITION_PCT=40.0

# Max total altcoin exposure as % of portfolio
MAX_TOTAL_EXPOSURE_PCT=85.0

# Max concurrent open positions (prevents thin positions on small balance)
# On $150: 3 positions × ~$40-50 each = concentrated, meaningful trades
MAX_OPEN_POSITIONS=3

# Risk profile — conservative | balanced | aggressive | fast_profit
RISK_PROFILE=aggressive

# Less-fear mode — lowers quant threshold, blocks auto-downgrade to conservative,
# forces Claude to approve high-score candidates even in fearful markets
LESS_FEAR=true

# Auto-adjust risk profile based on market regime (true/false)
# NOTE: has no effect when LESS_FEAR=true (less-fear locks the profile)
AUTO_RISK_PROFILE=true

# Max drawdown circuit breaker — pauses bot if portfolio drops this % from peak
MAX_DRAWDOWN_PCT=15.0

# Discord webhook URL for trade notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=

# ─── Auto-backtest & tuning ───────────────────────────────────────────────────
# Run backtest on bot startup to auto-tune scorer settings (true/false)
AUTO_BACKTEST=true
# Re-run backtest every N hours (0 = startup only)
BACKTEST_INTERVAL_HOURS=6
# Days of history per backtest (30 = good balance of speed vs accuracy)
BACKTEST_DAYS=30
# Symbols to include in backtest
BACKTEST_SYMBOLS=16

# ─── DCA (Dollar-Cost Averaging) ─────────────────────────────────────────────
# Split BUY into 2 tranches for better average entry (true/false)
DCA_ENABLED=true
# First tranche as % of total position (rest is pending limit order)
DCA_SPLIT_PCT=60
# Dip % below entry for second tranche to fill
DCA_DIP_PCT=2.0

# ─── Kelly criterion sizing ──────────────────────────────────────────────────
# Scale position sizes using Kelly formula from backtest results.
# Disable for small balances (<$500) — Kelly collapses positions to the $6
# minimum notional when win-rate is uncertain. Use raw quant sizing instead.
KELLY_SIZING=false
# Cap on Kelly fraction (0.5 = half-Kelly for safety)
KELLY_FRACTION_CAP=0.5

# ─── Time-based exit ─────────────────────────────────────────────────────────
# Max hours to hold a stagnant position (0 = disabled)
MAX_HOLD_HOURS=48

# ─── Pyramiding (add to winners) ─────────────────────────────────────────────
# Add to profitable positions when quant score remains high
PYRAMID_ENABLED=true
# Minimum P&L % before pyramiding is considered
PYRAMID_MIN_PNL_PCT=3.0
# Minimum quant score for pyramiding
PYRAMID_MIN_SCORE=70
# How much to add as % of original position value
PYRAMID_ADD_PCT=50

# ─── Quant scorer (signal-first architecture) ────────────────────────────────
# Minimum score (0-100) for a symbol to become a trade candidate
MIN_QUANT_SCORE=50
# ATR multiplier for stop-loss (1.5 = normal volatility buffer)
SL_ATR_MULTIPLIER=1.5
# Minimum reward-to-risk ratio (TP must be this multiple of SL)
MIN_REWARD_RISK_RATIO=2.0
# Stop-loss % floor and ceiling
MIN_SL_PCT=1.5
MAX_SL_PCT=10.0

# ─── Trailing take-profit ─────────────────────────────────────────────────────
# Once TP is hit, stay in the trade and only sell when price pulls back this %
# from its peak above TP. 6% gives trending coins room to breathe vs 3% default.
TRAILING_TP_PULLBACK_PCT=6.0
# Safety floor: if price drops back below the original TP level, sell immediately
TRAILING_TP_FLOOR=true
# Minutes to wait before re-entering a symbol after a take-profit exit.
# Prevents the bot churning in/out of the same trending coin every few hours.
TP_COOLDOWN_MINUTES=45

# ─── Smart exit engine ──────────────────────────────────────────────────────
# Runs every cycle: GPU Exit RL + local reversal detector + profit lock.
# Analyses indicators (RSI, MACD, VWAP, OBV, BTC trend, ensemble, anomaly)
# and exits positions showing reversal signals — no static rules needed.
SMART_EXIT_ENABLED=true

# ─── Profit lock (protect unrealised gains before TP) ───────────────────────
# Sliding floor: sell when gains drop to max(FLOOR, peak × KEEP%).
#   peaked +3%  → floor = max(1%, 3%×50%) = 1.5%  → sell at +1.5%
#   peaked +5%  → floor = max(1%, 5%×50%) = 2.5%  → sell at +2.5%
#   peaked +10% → floor = max(1%, 10%×50%) = 5.0% → sell at +5.0%
# Set ACTIVATE=0 to disable.
PROFIT_LOCK_ACTIVATE_PCT=3.0
PROFIT_LOCK_FLOOR_PCT=1.0
PROFIT_LOCK_KEEP_PCT=50.0

# ─── Whale trade detector ───────────────────────────────────────────────────
# Minimum single trade value (USDT) to count as whale flow
WHALE_MIN_USDT=50000
# How many minutes whale events are kept in memory
WHALE_MEMORY_MINUTES=30
# Verify Binance WS TLS certificates (recommended true)
WHALE_WS_VERIFY_SSL=true
# If cert validation fails (self-signed/intercepting chain), allow one-time
# fallback to insecure websocket TLS so detector can continue running.
WHALE_WS_INSECURE_FALLBACK=true

# ─── Cost optimisation ────────────────────────────────────────────────────────
# Max symbols sent to Claude per cycle (0 = all, recommended 5-8)
MAX_PROMPT_SYMBOLS=15
# Skip Claude when market is flat and no strong signals (true/false)
SKIP_FLAT_CYCLES=true
# Use cheaper Haiku model for quiet cycles, Sonnet for actionable (true/false)
USE_HAIKU_FOR_HOLD=true
# Express lane: skip Claude validation when LESS_FEAR=true (saves API calls —
# we override Claude's HOLD decisions anyway, so the call is pure waste)
EXPRESS_SKIP_CLAUDE_WHEN_LESS_FEAR=true
# Hard cap: max Claude calls the express lane may make per 60-second window
EXPRESS_MAX_CLAUDE_PER_MINUTE=1
# Hard cap: max Claude calls the express lane may make per hour (0 = unlimited)
EXPRESS_MAX_CLAUDE_PER_HOUR=4
# Per-symbol cooldown (minutes) — don't re-call Claude for the same symbol
# within this window even if it stays hot. 0 = disabled.
EXPRESS_CLAUDE_SYMBOL_COOLDOWN_MIN=15

# Main-cycle Claude gating — call Claude only when ALL local models agree.
# By default the cycle auto-HOLDs; Claude is only involved when quant + GPU
# ensemble + MTF all point the same direction at sufficient confidence.
#
# Tier 1: Skip Claude on main cycle when LESS_FEAR=true (we override it anyway)
MAIN_CYCLE_SKIP_CLAUDE_WHEN_LESS_FEAR=true
# Tier 2: High-conviction GPU bypass — if score >= this AND GPU BUY, execute
#   directly without Claude (0 = disabled). Recommended: 75.0
SKIP_CLAUDE_ABOVE_SCORE=75.0
# Minimum GPU ensemble confidence required for the GPU bypass
SKIP_CLAUDE_GPU_MIN_CONFIDENCE=0.65
# Tier 3: Hard hourly cap on main-cycle Claude calls (0 = unlimited)
MAIN_CYCLE_MAX_CLAUDE_PER_HOUR=4

# Universe volume floor for USDC pairs — much lower than USDT since USDC pairs
# trade at 10-20× less volume. $300K covers the full mid-cap USDC universe.
MIN_VOLUME_USDT_USDC=300000

# Top gainers detection: min 24h % change to inject into universe
GAINER_MIN_PCT=5.0
# Max gainers to inject per cycle (on top of volume-based universe)
GAINER_INJECT_COUNT=10
# Min 24h volume for a gainer to be injected — independent of MIN_VOLUME_USDT
# Set low to catch USDC pairs with lower liquidity (e.g. ONT/USDC)
GAINER_MIN_VOLUME_USDT=50000
# How many hours to auto-track newly listed coins (they get injected regardless of volume)
NEW_LISTING_WATCH_HOURS=1

# ─── Fast scanner ─────────────────────────────────────────────────────────────
# Background scanner interval (seconds)
SCANNER_INTERVAL_SECONDS=60
# Min 24h volume to include in scan — lower than main universe to catch breakouts early
SCANNER_MIN_VOLUME_USDT=75000
# Max hot-list size injected into main cycle
SCANNER_HOT_LIST_SIZE=15
# Min composite score (0-100) to qualify as hot
SCANNER_MIN_SCORE=12.0

# ─── News ─────────────────────────────────────────────────────────────────────
# CryptoCompare free API key (optional — leave blank for unauthenticated calls)
CRYPTOCOMPARE_API_KEY=

# ─── Remote GPU server (optional) ────────────────────────────────────────────
# Point to a machine running gpu-server/server.py for Transformer model,
# Dueling Double DQN, semantic sentiment, and full ensemble endpoint.
# No GPU required — the server falls back to CPU if CUDA is unavailable.
# Run locally: cd gpu-server && pip install -r requirements.txt && python server.py
GPU_SERVER_URL=http://localhost:9090
GPU_SERVER_TIMEOUT=120
# Shared auth token — must match GPU_SERVER_TOKEN on the GPU machine (leave blank to disable)
GPU_SERVER_TOKEN=

# ─── Local LLM (Ollama) ───────────────────────────────────────────────────────
# When enabled, the bot uses a local Qwen 2.5 model for trade validation
# instead of the Claude API, falling back to Claude if Ollama is unreachable.
# Ollama is started automatically by gpu-server/server.py — no extra setup needed
# once you run: cd gpu-server && .\setup.ps1
USE_LOCAL_LLM=true
# Ollama base URL. Leave blank to auto-derive from GPU_SERVER_URL (same host,
# port 11434). Set explicitly only if Ollama runs on a different machine.
LOCAL_LLM_URL=
# Model to use. qwen2.5:14b requires ~9.4 GB VRAM. Use qwen2.5:7b on CPU.
LOCAL_LLM_MODEL=qwen2.5:7b
# Inference timeout in seconds. GPU: ~5-15s. CPU (7B): ~60-120s. CPU (14B): ~180s.
LOCAL_LLM_TIMEOUT=120

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production / Docker deployment)
DATABASE_URL=postgresql+asyncpg://ai_trader:ai_trader@localhost:5432/ai_trader
# SQLite alternative (for quick local dev without PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:////data/trader.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
