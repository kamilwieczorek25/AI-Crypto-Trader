# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Admin API key for credit balance display (optional)
# Generate at: https://console.anthropic.com/settings/admin-keys
# Format: sk-ant-admin01-...
ANTHROPIC_ADMIN_KEY=

# ─── Binance ──────────────────────────────────────────────────────────────────
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Trading mode ─────────────────────────────────────────────────────────────
# "demo" (default) — paper trading only
# "real"           — live orders (also requires REAL_TRADING=true)
MODE=demo

# Second safety gate: must be explicitly "true" to allow live orders
REAL_TRADING=false

# ─── Bot behaviour ────────────────────────────────────────────────────────────
# How often the bot runs a full analysis cycle (seconds)
CYCLE_INTERVAL_SECONDS=300

# Starting paper-money balance for demo mode (USDT)
DEMO_INITIAL_BALANCE=10000.0

# Max % of total portfolio in a single trade (hard cap)
MAX_POSITION_PCT=5.0

# Max total altcoin exposure as % of portfolio
MAX_TOTAL_EXPOSURE_PCT=70.0

# ─── Symbol universe ──────────────────────────────────────────────────────────
# Minimum 24h USDT trading volume to be included (filters illiquid pairs)
MIN_VOLUME_USDT=10000000

# Hard cap on number of symbols analysed per cycle (0 = all passing the volume filter)
TOP_N_SYMBOLS=0

# Max concurrent OHLCV/orderbook API fetches (higher = faster but more rate-limit risk)
FETCH_CONCURRENCY=10

# ─── News ─────────────────────────────────────────────────────────────────────
# CryptoCompare free API key (optional — leave blank for unauthenticated calls)
CRYPTOCOMPARE_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////data/trader.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
